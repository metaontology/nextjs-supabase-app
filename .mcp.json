{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--cdp-endpoint",
        "http://172.17.0.1:19222"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "shrimp-task-manager": {
      "command": "node",
      "args": ["/home/hgjun/workspace/library/claude/mcp/mcp-shrimp-task-manager/dist/index.js"],
      "env": {
        "DATA_DIR": "./shrimp_data",
        "TEMPLATES_USE": "en",  
        "ENABLE_GUI": "false"
      }
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "env": {}
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=vcpdwcanwnjywuvczkfu",
      "headers": {
        "Authorization": "Bearer sbp_3132e314f0490e3104754018ec9026b42a277eb0"
      }
    }
  }
}